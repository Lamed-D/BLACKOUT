# ── Database Configuration ─────────────────────────────────────
# 도커 컨테이너 내부 환경변수와 일치해야 합니다.
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=blackout_db
DB_USER=blackout_user
DB_PASSWORD=blackout_pass
MYSQL_ROOT_PASSWORD=blackout_root

# ── Flask Configuration ────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=yoursecretkeyhere

# ── Social Login Configuration (OAuth) ──────────────────────────
# 각 플랫폼 개발자 센터에서 발급받은 키를 여기에 입력하세요.

# Google: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Naver: https://developers.naver.com/apps/
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# Kakao: https://developers.kakao.com/
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
